modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["docker", "docker-compose"]

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.sendgrid.net"
SMTP_PORT = "587"
SMTP_FROM_EMAIL = "notifications@siebertservices.com"
SMTP_FROM_NAME = "Siebert Services"
NOTIFICATION_EMAIL = "sales@siebertservices.com"
