modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "node artifacts/api-server/dist/index.cjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.office365.com"
SMTP_PORT = "587"
SMTP_FROM_EMAIL = "notifications@siebertrservices.com"
SMTP_FROM_NAME = "Siebert Services"
NOTIFICATION_EMAIL = "sales@siebertrservices.com"
MICROSOFT_REDIRECT_URI = "https://siebertrservices.com/api/auth/sso/microsoft/callback"
ZOOM_PHONE_NUMBER = "+1-845-908-0123"
OKTA_CLIENT_ID = "paste_your_client_id_here"
OKTA_CLIENT_SECRET = "paste_your_client_secret_here"
OKTA_DOMAIN = "yourname.okta.com"
OKTA_REDIRECT_URI = "https://yourdomain.com/api/auth/sso/okta/callback"

[nix]
channel = "stable-25_05"
