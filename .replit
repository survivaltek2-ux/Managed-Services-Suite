modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "node artifacts/api-server/dist/index.cjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
SMTP_FROM_EMAIL = "notifications@siebertrservices.com"
SMTP_FROM_NAME = "Siebert Services"
MICROSOFT_REDIRECT_URI = "https://siebertrservices.com/api/auth/sso/microsoft/callback"
ZOOM_PHONE_NUMBER = "+1-845-908-0123"
OKTA_CLIENT_ID = "0oa11ir8ysjLdzGp9698"
