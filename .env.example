# ============================================================
# Siebert Services — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ------------------------------------------------------------
# Database (required)
# PostgreSQL connection string
# ------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/siebert_services

# ------------------------------------------------------------
# Environment
# ------------------------------------------------------------
NODE_ENV=production

# ------------------------------------------------------------
# API Server authentication (required)
# Change JWT_SECRET to a long random string in production
# ------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-secret

# Server port for the API (defaults to 8080)
PORT=8080

# ------------------------------------------------------------
# AI Chat Assistant (required for AI chat widget)
# Use your own OpenAI API key when hosting outside Replit
# ------------------------------------------------------------
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# ------------------------------------------------------------
# Email / SMTP (optional — gracefully degrades if not set)
# Used for deal submission and support ticket notifications
# ------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM_EMAIL=noreply@siebertservices.com
# SMTP_FROM_NAME=Siebert Services
# NOTIFICATION_EMAIL=admin@siebertservices.com

# ------------------------------------------------------------
# Microsoft SSO (optional — only needed for MS SSO login)
# ------------------------------------------------------------
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=https://yourdomain.com/api/auth/sso/microsoft/callback

# ------------------------------------------------------------
# Frontend build variables (set at build time)
# PORT and BASE_PATH default to sensible values if not set:
#   siebert-services: PORT=3000, BASE_PATH=/
#   partner-portal:   PORT=3001, BASE_PATH=/partners/
# ------------------------------------------------------------
# BASE_PATH=/
